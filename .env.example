# Netlify Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google AdSense Configuration (publisher ID is also fallback in code)
VITE_ADSENSE_PUBLISHER_ID=ca-pub-5932083189692902
VITE_ADSENSE_ENABLED=true

# Optional: set these in Vercel after creating ad units in AdSense (numeric slot IDs)
# VITE_ADSENSE_SLOT_TOP=1234567890
# VITE_ADSENSE_SLOT_BOTTOM=1234567890
# VITE_ADSENSE_SLOT_SIDEBAR=1234567890
# VITE_ADSENSE_SLOT_INCONTENT=1234567890
# VITE_ADSENSE_SLOT_HEADER=1234567890
# VITE_ADSENSE_SLOT_FOOTER=1234567890
# VITE_ADSENSE_SLOT_RESPONSIVE=1234567890

# For development (optional)
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
