[{"id":"y1_E_Can_Q526","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"easy","question_text":"Apprentice training periods in Alberta?","option_a":"4 periods, 1500 hrs","option_b":"3 periods, 1200 hrs","option_c":"5 periods, 2000 hrs","option_d":"1 period, 800 hrs","correct_answer":"A","explanation":"A correct: Electrician apprenticeship is 4x 8-week periods + 1560 on-job hrs. Others mismatch AIT structure.","reference":"AIT Curriculum Guide p.11","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q534","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"medium","question_text":"Incident reporting timeline?","option_a":"Immediate to supervisor","option_b":"End of shift","option_c":"Weekly","option_d":"Monthly","correct_answer":"A","explanation":"A correct: OH&S requires prompt notification. Delays risk recurrence.","reference":"Alberta OH&S, AIT FS","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q525","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"easy","question_text":"First step in risk assessment?","option_a":"Identify hazards","option_b":"Select PPE","option_c":"Lockout/Tagout","option_d":"Call supervisor","correct_answer":"A","explanation":"A correct: Hazard ID precedes controls per CSA Z462. B,C,D follow assessment; supervisor not first.","reference":"AIT Period 1 FS 11%, CSA Z462","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q529","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"easy","question_text":"WHMIS hazard symbol for flammable?","option_a":"Flame icon","option_b":"Skull/crossbones","option_c":"Corrosive hand","option_d":"Explosive burst","correct_answer":"A","explanation":"A correct: Flame for flammables. B=toxic, C=corrosive, D=explosive.","reference":"WHMIS, AIT FS","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q527","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"easy","question_text":"Multimeter for voltage?","option_a":"Red to hot, black neutral","option_b":"Red/black reversed","option_c":"AC only on DC setting","option_d":"Current mode","correct_answer":"A","explanation":"A correct: Standard polarity for DC/AC voltage. B risks damage; C,D wrong functions.","reference":"AIT TL 2%, Tools","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q532","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"easy","question_text":"PPE hierarchy top?","option_a":"Elimination","option_b":"Engineering controls","option_c":"Admin controls","option_d":"PPE","correct_answer":"A","explanation":"A correct: Eliminate hazard first per CSA Z1000. PPE last resort.","reference":"AIT FS Safety","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q530","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"medium","question_text":"Megger tests?","option_a":"Insulation resistance","option_b":"Continuity","option_c":"Voltage drop","option_d":"Capacitance","correct_answer":"A","explanation":"A correct: Insulation at high voltage (e.g., 500V). Others basic multimeter.","reference":"AIT TL Instruments","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q537","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"hard","question_text":"Competent person def?","option_a":"Qualified + experienced","option_b":"Trained 1 day","option_c":"Supervisor only","option_d":"Any worker","correct_answer":"A","explanation":"A correct: OH&S: knowledge + training + experience. Others insufficient.","reference":"Alberta OH&S","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q533","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"easy","question_text":"Lineman pliers for?","option_a":"Twisting/cutting wire","option_b":"Measuring voltage","option_c":"Soldering","option_d":"Drilling","correct_answer":"A","explanation":"A correct: Heavy-duty cutting/twisting. Others wrong tool.","reference":"AIT TL 2%","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q535","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"easy","question_text":"SDS stands for?","option_a":"Safety Data Sheet","option_b":"Site Danger Survey","option_c":"Standard Duty Spec","option_d":"Safety Device System","correct_answer":"A","explanation":"A correct: WHMIS doc for hazmat. Others fabricated.","reference":"WHMIS, AIT FS","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q536","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"medium","question_text":"Clamp meter measures?","option_a":"Current non-contact","option_b":"Voltage only","option_c":"Insulation","option_d":"Frequency","correct_answer":"A","explanation":"A correct: AC/DC current via jaws. Others probes/other.","reference":"AIT TL","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q528","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"medium","question_text":"LOTO purpose?","option_a":"De-energize & prevent re-energize","option_b":"Test voltage only","option_c":"Isolate ground","option_d":"Verify PPE","correct_answer":"A","explanation":"A correct: Lockout/Tagout full procedure per OH&S. Others partial or post-LOTO.","reference":"CSA Z462, AIT FS","trade":"electrician","country":"CA"},{"id":"y1_E_Can_Q531","year":1,"section":1,"section_name":"SKILLS, RESP AND TOOLS, EQUIPMENTS","difficulty":"hard","question_text":"Due diligence under OH&S?","option_a":"Proactive hazard control","option_b":"Reactive incident reports","option_c":"PPE issuance only","option_d":"Training logs","correct_answer":"A","explanation":"A correct: Employer duty to anticipate/prevent. Others compliance tools.","reference":"Alberta OH&S, AIT FS","trade":"electrician","country":"CA"}]